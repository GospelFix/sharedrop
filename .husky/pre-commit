# .husky/pre-commit (sh 호환)
#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# 1) 스테이징된 파일에 main/ 변화가 있으면 빌드
if git diff --cached --name-only | grep -q '^main/'; then
  echo "🔨 main/ 변경 감지 → build 실행"
  # npm 사용 시: npm --prefix main run build
  yarn --cwd main install --frozen-lockfile || exit 1
  yarn --cwd main build || exit 1
else
  echo "ℹ️ main/ 변경 없음 → build 스킵"
fi

# 기존 작업 유지
npx lint-staged || exit 1
yarn test || exit 1
