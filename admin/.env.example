# Supabase
# Settings > General > Project URL
NEXT_PUBLIC_SUPABASE_URL=your-project-url
# Settings > API Keys > Publishable key (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key
# Settings > API Keys > Secret key (sb_secret_...) — 서버 전용, 절대 클라이언트 노출 금지
SUPABASE_SERVICE_ROLE_KEY=your-secret-key

# Google OAuth (Supabase 대시보드에서 설정)
GOOGLE_OAUTH_ID=
GOOGLE_OAUTH_SECRET=

# Kakao OAuth (Supabase 대시보드에서 설정)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# Supabase CLI 전용 (supabase start 후 자동 생성)
# SUPABASE_PROJECT_ID=your-project-id
# SUPABASE_DB_PASSWORD=your-db-password
# SUPABASE_ACCESS_TOKEN=your-access-token
